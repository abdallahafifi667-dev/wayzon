# ═══════════════════════════════════════════════════════════════════════════
# Trip Monitoring Server - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/tripMonitoring
# For Docker: MONGODB_URI=mongodb://mongo:27017/tripMonitoring

# ─────────────────────────────────────────────────────────────────────────────
# Redis Cache Configuration
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# For Docker: REDIS_URL=redis://redis:6379


# ─────────────────────────────────────────────────────────────────────────────
# ML Brain Python Service Configuration
# ─────────────────────────────────────────────────────────────────────────────
# URL of the Python ML Brain FastAPI service
ML_BRAIN_URL=http://localhost:8001
# For Docker: ML_BRAIN_URL=http://ml-brain:8000

# Enable/disable ML Brain integration (fallback to legacy if disabled)
ML_BRAIN_ENABLED=true

# Timeout for ML Brain HTTP requests (in ms)
ML_BRAIN_TIMEOUT=5000

# Enable production mode (scheduled training, weekly reports)
ML_BRAIN_PRODUCTION=false

# ─────────────────────────────────────────────────────────────────────────────
# External APIs
# ─────────────────────────────────────────────────────────────────────────────
# Google AI / Gemini
GOOGLE_API_KEY=your_google_api_key_here

# Google Maps
GOOGLE_MAPS_API_KEY=your_maps_api_key_here

# YouTube Data API (for video risk analysis)
YOUTUBE_API_KEY=your_youtube_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Security & Authentication
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────────────────────
# Firebase Cloud Messaging (FCM)
# ─────────────────────────────────────────────────────────────────────────────
FCM_SERVER_KEY=your_fcm_server_key_here
