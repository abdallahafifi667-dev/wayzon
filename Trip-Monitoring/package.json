{
  "name": "safety-tracking-service",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "node ./bin/www",
    "start:debug": "node --inspect ./bin/www",
    "start:prod": "node dist/main",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down --remove-orphans",
    "docker:clean": "docker rm -f trip-redis ml-brain || echo Containers already cleared",
    "docker:fix": "npm run docker:down && npm run docker:clean && npm run docker:up",
    "docker:reset": "docker-compose down -v && npm run docker:clean && docker-compose up -d",
    "format": "npx prettier . --write"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.975.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@google-cloud/vision": "^5.3.4",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.13.4",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "busboy": "^1.6.0",
    "clamscan": "^2.4.0",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.6",
    "debug": "~2.6.9",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-async-handler": "^1.2.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "express-useragent": "^1.0.15",
    "express-validator": "^7.3.1",
    "file-type": "^21.3.0",
    "firebase-admin": "^13.6.0",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "http-errors": "~1.6.3",
    "joi": "^17.13.3",
    "joi-password-complexity": "^5.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.21.1",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.2",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.13",
    "nodemon": "^3.1.11",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "redis": "^4.7.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "streamifier": "^0.1.1",
    "tslib": "^2.8.1",
    "ua-parser-js": "^2.0.8",
    "validator": "^13.15.26",
    "xss": "^1.0.15",
    "xss-clean": "^0.1.4"
  }
}